@model JokesWebApp.Models.Joke

@{
    ViewData["Title"] = "Delete";
}

<div class="page-header">
    <h1 class="page-title">Delete Joke</h1>
    <p class="page-subtitle delete-warning">Are you sure you want to delete this? This cannot be undone.</p>
</div>

<div class="content-card">
    <dl class="row detail-list mb-4">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.JokeQuestion)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.JokeQuestion)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.JokeAns)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.JokeAns)
        </dd>
    </dl>

    <form asp-action="Delete" class="d-flex gap-2 flex-wrap align-items-center">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
