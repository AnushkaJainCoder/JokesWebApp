@model IEnumerable<JokesWebApp.Models.Joke>

@{
    ViewData["Title"] = "Jokes";
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <h1 class="page-title">Your Jokes</h1>
        <p class="page-subtitle">Manage all jokes in your collection.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-create">+ Create New</a>
</div>

<div class="content-card p-0 overflow-hidden">
    <table class="table jokes-table mb-0">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.JokeQuestion)
                </th>
                <th>
                    User Email
                </th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.JokeQuestion)
                </td>
                <td>
                    @User.Identity?.Name
                </td>
                <td class="text-end action-links">
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger">Delete</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
