@model JokesWebApp.Models.Joke

@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <h1 class="page-title">Joke Details</h1>
    <p class="page-subtitle">View the full question and answer.</p>
</div>

<div class="content-card">
    <dl class="row detail-list mb-0">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.JokeQuestion)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.JokeQuestion)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.JokeAns)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.JokeAns)
        </dd>
    </dl>
</div>

<div class="d-flex gap-2 flex-wrap">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
